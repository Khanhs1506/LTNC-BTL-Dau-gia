<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="551.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sample.LoginController">
   <right>
      <AnchorPane prefHeight="400.0" prefWidth="334.0" style="-fx-background-color: #ECECE7;" BorderPane.alignment="CENTER">
         <children>

            <!-- Icon khóa -->
            <ImageView fx:id="lockImageView" fitHeight="32.0" fitWidth="46.0" layoutX="149.0" layoutY="52.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../images/o_khoa.png" />
               </image>
            </ImageView>

            <!-- Tên Đăng Nhập -->
            <Label layoutX="32.0" layoutY="119.0" text="Tên Đăng Nhập">
               <font><Font size="13.0" /></font>
            </Label>
            <TextField fx:id="usernameTextField" layoutX="125.0" layoutY="116.0" prefHeight="26.0" prefWidth="178.0" promptText="Nhập tên đăng nhập" style="-fx-background-color: transparent;                               -fx-border-color: #a9a9a9;                               -fx-border-width: 0px 0px 1px 0px;" />

            <!-- Mật Khẩu -->
            <Label layoutX="32.0" layoutY="176.0" text="Mật Khẩu">
               <font><Font size="13.0" /></font>
            </Label>
            <PasswordField fx:id="enterPasswordField" layoutX="125.0" layoutY="172.0" prefHeight="26.0" prefWidth="178.0" promptText="Nhập mật khẩu" style="-fx-background-color: transparent;                                   -fx-border-color: #a9a9a9;                                   -fx-border-width: 0px 0px 1px 0px;" />

            <!-- Thông báo -->
            <Label fx:id="loginMessageLabel" alignment="CENTER" layoutX="48.0" layoutY="217.0" prefHeight="19.0" prefWidth="222.0" text="Xin mời nhập thông tin" textFill="#e75c2d">
               <font><Font size="13.0" /></font>
            </Label>

            <!-- Nút Đăng Nhập -->
            <Button fx:id="loginButton" layoutX="35.0" layoutY="251.0" mnemonicParsing="false" onAction="#loginButtonOnAction" prefHeight="32.0" prefWidth="249.0" style="-fx-background-color: #E96151;" text="Đăng Nhập" textFill="WHITE">
               <font><Font size="13.0" /></font>
            </Button>

            <!-- Nút Thoát -->
            <Button fx:id="cancelButton" layoutX="35.0" layoutY="293.0" mnemonicParsing="false" onAction="#cancelButtonAction" prefHeight="32.0" prefWidth="249.0" style="-fx-background-color: #E96151;" text="Thoát" textFill="WHITE">
               <font><Font size="13.0" /></font>
            </Button>

         </children>
      </AnchorPane>
   </right>

   <left>
      <AnchorPane prefHeight="400.0" prefWidth="223.0" style="-fx-background-color: #ECECE7;" BorderPane.alignment="CENTER">
         <children>
            <ImageView fx:id="brandingImageView" fitHeight="400.0" fitWidth="222.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../images/logo_new.png" />
               </image>
            </ImageView>
         </children>
      </AnchorPane>
   </left>
</BorderPane>
