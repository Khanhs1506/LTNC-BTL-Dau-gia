<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="620.0" prefWidth="700.0"
            style="-fx-background-color: #FDFCF8;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="sample.AuctionDetailController">

    <!-- Header -->
    <VBox AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <HBox style="-fx-background-color: #c0392b; -fx-padding: 16 24;"
              spacing="12">
            <Label text="CHI TIẾT PHIÊN ĐẤU GIÁ"
                   style="-fx-text-fill: white; -fx-font-size: 17; -fx-font-weight: bold;"/>
        </HBox>

        <!-- Thông tin chính -->
        <VBox style="-fx-background-color: #fdf6e3; -fx-padding: 20 28;" spacing="10">

            <Label fx:id="itemNameLabel" text="---"
                   style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #222;"/>

            <HBox spacing="40">
                <VBox spacing="4">
                    <Label text="Giá khởi điểm" style="-fx-text-fill: #888; -fx-font-size: 12;"/>
                    <Label fx:id="startingPriceLabel" text="---"
                           style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #444;"/>
                </VBox>
                <VBox spacing="4">
                    <Label text="Giá cao nhất hiện tại" style="-fx-text-fill: #888; -fx-font-size: 12;"/>
                    <Label fx:id="currentBidLabel" text="---"
                           style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #c0392b;"/>
                </VBox>
                <VBox spacing="4">
                    <Label text="Thời gian kết thúc" style="-fx-text-fill: #888; -fx-font-size: 12;"/>
                    <Label fx:id="endTimeLabel" text="---"
                           style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #444;"/>
                </VBox>
            </HBox>

            <!-- Đếm ngược -->
            <Label fx:id="countdownLabel" text="⏳ --:--:--"
                   style="-fx-font-size: 22; -fx-font-weight: bold;
                       -fx-text-fill: #c0392b; -fx-padding: 6 0 0 0;"/>

        </VBox>

        <!-- Đồ thị -->
        <VBox style="-fx-padding: 16 24 0 24;" spacing="8">
            <Label text="Lịch sử giá thầu"
                   style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #555;"/>
            <LineChart fx:id="bidChart" prefHeight="180">
                <xAxis><CategoryAxis label="Thời gian"/></xAxis>
                <yAxis><NumberAxis label="Giá (VNĐ)"/></yAxis>
            </LineChart>
        </VBox>

        <!-- Đặt giá -->
        <VBox style="-fx-padding: 16 24;" spacing="10">
            <Label text="Đặt giá của bạn"
                   style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #555;"/>

            <HBox spacing="10">
                <TextField fx:id="bidAmountField"
                           promptText="Nhập số tiền (VNĐ)"
                           prefWidth="300"
                           style="-fx-background-color: white;
                              -fx-border-color: #ddd;
                              -fx-border-radius: 6;
                              -fx-background-radius: 6;
                              -fx-padding: 8 12;
                              -fx-font-size: 13;"/>
                <Button fx:id="placeBidButton" text="Đặt Giá"
                        onAction="#placeBidOnAction"
                        style="-fx-background-color: #c0392b;
                           -fx-text-fill: white;
                           -fx-font-weight: bold;
                           -fx-font-size: 13;
                           -fx-padding: 8 24;
                           -fx-background-radius: 6;
                           -fx-cursor: hand;">
                    <font><Font size="13.0"/></font>
                </Button>
            </HBox>

            <Label fx:id="messageLabel" text=""
                   style="-fx-font-size: 13; -fx-text-fill: #e05252;"/>
        </VBox>

    </VBox>

</AnchorPane>