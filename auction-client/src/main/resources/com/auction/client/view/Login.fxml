<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.LoginController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <Label text="HỆ THỐNG ĐẤU GIÁ">
        <font>
            <Font name="System Bold" size="24.0" />
        </font>
    </Label>

    <TextField fx:id="txtUsername" promptText="Tên đăng nhập" prefWidth="250.0"/>

    <PasswordField fx:id="txtPassword" promptText="Mật khẩu" prefWidth="250.0"/>

    <Label fx:id="lblError" textFill="RED" wrapText="true" />

    <Button mnemonicParsing="false" onAction="#handleLogin" prefWidth="250.0" text="Đăng nhập" style="-fx-background-color: #007bff; -fx-text-fill: white; -fx-font-weight: bold;"/>

    <Button mnemonicParsing="false" onAction="#handleRegister" prefWidth="250.0" text="Chưa có tài khoản? Đăng ký ngay" style="-fx-background-color: transparent; -fx-text-fill: #007bff; -fx-underline: true;"/>
</VBox>
